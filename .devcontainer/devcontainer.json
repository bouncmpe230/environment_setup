// For format details, see https://aka.ms/devcontainer.json.
{
  "name": "cmpe230_spring26",
  "context": "..",
  "dockerFile": "../containers/spring26/Dockerfile",

  "remoteUser": "bouncmpe230",
  "workspaceFolder": "/home/bouncmpe230/workspace",

  "mounts": [
    "source=${localWorkspaceFolder},target=/home/bouncmpe230/workspace,type=bind,consistency=cached",
    "source=cmpe230-bash-history,target=/home/bouncmpe230/.bash_history,type=volume"
  ],

  "settings": {
    "terminal.integrated.defaultProfile.linux": "bash",
    "editor.formatOnSave": true,
    "files.eol": "\n",
    "C_Cpp.default.configurationProvider": "ms-vscode.cmake-tools"
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "ms-vscode.cpptools-extension-pack",
        "ms-vscode.cmake-tools",
        "ms-azuretools.vscode-docker",
        "timonwong.shellcheck",
        "mhutchie.git-graph",
        "13xforever.language-x86-64-assembly"
      ]
    }
  },

  "postCreateCommand": "mkdir -p ~/workspace && git config --global --add safe.directory '*' && git config --global core.editor vim",

  "features": {
    "ghcr.io/devcontainers/features/git:1": {}
  }
}